{
	"name": "next-lxd-sftp",
	"version": "v1.0.0",
	"description": "LXD instance SFTP operations via a Node.js native addon — cross-platform (Go → C++ → N-API)",
	"main": "index.js",
	"types": "index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/urixen-org/next-lxd-sftp.git"
	},
	"binary": {
		"module_name": "next-lxd",
		"module_path": "./build/Release",
		"host": "https://github.com/urixen-org/next-lxd-sftp/releases/download/",
		"remote_path": "{version}"
	},
	"scripts": {
		"install": "node-pre-gyp install || node build.js",
		"build": "node build.js",
		"build:debug": "node build.js --debug",
		"build:release": "node build.js",
		"rebuild": "node build.js --no-clean",
		"clean": "node-pre-gyp clean",
		"test": "node test.js",
		"package": "node build.js && node-pre-gyp package",
		"publish": "node-pre-gyp-github publish"
	},
	"keywords": [
		"lxd",
		"sftp",
		"native",
		"addon",
		"gonacli",
		"n-api"
	],
	"author": "nehxurai@urixen.io",
	"license": "MIT",
	"dependencies": {
		"@mapbox/node-pre-gyp": "^2.0.0",
		"bindings": "^1.5.0",
		"node-addon-api": "^8.9.0",
		"node-pre-gyp-github": "^2.0.0"
	},
	"gypfile": false
}
